# ============================================================================
# Filing System Configuration
# ============================================================================
# This file contains all environment variables required for the filing system.
# Copy this to .env.local and fill in your actual values.
#
# SECURITY: Never commit actual credentials to this file or to Git.
# Use .env.local (gitignored) for real credentials.

# ============================================================================
# General Filing Configuration
# ============================================================================

# Enable/disable filing system
FILING_SYSTEM_ENABLED=true

# Filing system mode: 'sandbox' or 'production'
FILING_MODE=sandbox

# Webhook configuration
FILING_WEBHOOK_SECRET=your-webhook-secret-key-here-min-32-chars

# Webhook URL for receiving status updates from SEDAR/SEC
WEBHOOK_URL=http://localhost:3000/api/filings/webhook

# Filing timeout (seconds)
FILING_REQUEST_TIMEOUT=30

# Maximum retries for failed submissions
FILING_MAX_RETRIES=3

# Retry backoff strategy: 'exponential' or 'linear'
FILING_RETRY_STRATEGY=exponential

# ============================================================================
# SEDAR 2 Configuration
# ============================================================================

# Enable SEDAR 2 adapter
SEDAR_ENABLED=true

# SEDAR mode: 'sandbox' or 'production'
SEDAR_MODE=sandbox

# SEDAR API credentials (OAuth2)
SEDAR_API_KEY=your-sedar-api-key
SEDAR_API_SECRET=your-sedar-api-secret
SEDAR_CLIENT_ID=your-sedar-client-id
SEDAR_CLIENT_SECRET=your-sedar-client-secret

# SEDAR OAuth2 Token URL
SEDAR_OAUTH_TOKEN_URL=https://auth-sandbox.sedarplus.ca/oauth/token

# SEDAR API Base URL
SEDAR_API_URL=https://api-sandbox.sedarplus.ca/v1
SEDAR_SANDBOX_URL=https://api-sandbox.sedarplus.ca/v1
SEDAR_PRODUCTION_URL=https://api.sedarplus.ca/v1

# SEDAR filing configuration
SEDAR_FILING_SYSTEM_ID=sedar_plus
SEDAR_DEFAULT_LANGUAGE=en

# SEDAR webhook configuration
SEDAR_WEBHOOK_ENABLED=true
SEDAR_WEBHOOK_URL=http://localhost:3000/api/filings/webhook
SEDAR_WEBHOOK_SECRET=${FILING_WEBHOOK_SECRET}

# ============================================================================
# SEC EDGAR Configuration
# ============================================================================

# Enable SEC EDGAR adapter
SEC_ENABLED=true

# SEC mode: 'sandbox' or 'production'
SEC_MODE=sandbox

# SEC API credentials
SEC_CIK=0000000001
SEC_API_KEY=your-sec-api-key
SEC_API_SECRET=your-sec-api-secret

# SEC API Base URL
SEC_API_URL=https://www.sec.gov/cgi-bin
SEC_SANDBOX_URL=https://www.sec.gov/cgi-bin
SEC_PRODUCTION_URL=https://www.sec.gov/cgi-bin

# SEC filing configuration
SEC_FILING_SYSTEM_ID=sec_edgar
SEC_DEFAULT_LANGUAGE=en

# SEC Company Information (CIK = Central Index Key)
SEC_COMPANY_CIK=${SEC_CIK}
SEC_COMPANY_NAME=Your Company Name

# SEC webhook configuration
SEC_WEBHOOK_ENABLED=true
SEC_WEBHOOK_URL=http://localhost:3000/api/filings/webhook
SEC_WEBHOOK_SECRET=${FILING_WEBHOOK_SECRET}

# ============================================================================
# Testing Configuration
# ============================================================================

# Enable test endpoints (NEVER enable in production)
FILING_TEST_ENDPOINTS_ENABLED=true

# Test mode (uses mock data instead of real APIs)
FILING_TEST_MODE=false

# Mock filing responses (for testing)
FILING_MOCK_ENABLED=true
FILING_MOCK_DELAY=100

# Test database URL (for running tests)
TEST_DATABASE_URL=postgresql://test:test@localhost:5432/ipoready_test

# ============================================================================
# Logging Configuration
# ============================================================================

# Logging level: 'debug', 'info', 'warn', 'error'
FILING_LOG_LEVEL=debug

# Log filing requests/responses
FILING_LOG_REQUESTS=true

# Log webhook events
FILING_LOG_WEBHOOKS=true

# Log adapter operations
FILING_LOG_ADAPTERS=true

# ============================================================================
# ngrok Configuration (for local webhook testing)
# ============================================================================

# ngrok URL (if testing locally with ngrok tunnel)
# WEBHOOK_URL=https://abc123.ngrok.io/api/filings/webhook
NGROK_TUNNEL_ENABLED=false
NGROK_TUNNEL_URL=

# ============================================================================
# Document Configuration
# ============================================================================

# Maximum document size (bytes)
FILING_MAX_DOCUMENT_SIZE=104857600

# Allowed document types
FILING_ALLOWED_DOCUMENT_TYPES=pdf,docx,xlsx,doc,xls

# Document storage backend: 's3', 'local', 'gcs'
FILING_DOCUMENT_STORAGE=local

# Local document storage path
FILING_DOCUMENTS_DIR=./documents/filings

# AWS S3 Configuration (if using S3 storage)
AWS_S3_BUCKET=ipoready-filings
AWS_S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ============================================================================
# Notification Configuration
# ============================================================================

# Send notifications on filing status changes
FILING_NOTIFICATIONS_ENABLED=true

# Notification channels: 'email', 'sms', 'webhook'
FILING_NOTIFICATION_CHANNELS=email,webhook

# Email notification settings
FILING_NOTIFICATION_EMAIL_FROM=filings@ipoready.com
FILING_NOTIFICATION_EMAIL_TO=admin@ipoready.com

# Slack notification settings
FILING_SLACK_WEBHOOK_URL=

# ============================================================================
# Rate Limiting
# ============================================================================

# Rate limit: requests per minute
FILING_RATE_LIMIT=60

# Rate limit window (milliseconds)
FILING_RATE_LIMIT_WINDOW=60000

# ============================================================================
# Performance & Caching
# ============================================================================

# Cache filing status (TTL in seconds)
FILING_STATUS_CACHE_TTL=300

# Cache filing documents (TTL in seconds)
FILING_DOCUMENT_CACHE_TTL=3600

# Enable request/response compression
FILING_COMPRESSION_ENABLED=true

# ============================================================================
# Security
# ============================================================================

# Require HTTPS for webhook requests
FILING_WEBHOOK_REQUIRE_HTTPS=false

# Allowed webhook IP addresses (comma-separated)
FILING_WEBHOOK_ALLOWED_IPS=

# API key authentication required
FILING_API_KEY_REQUIRED=true

# API keys (comma-separated)
FILING_API_KEYS=

# ============================================================================
# Development/Debugging
# ============================================================================

# Enable debug mode
DEBUG=filing:*

# Enable verbose logging
VERBOSE=true

# Disable SSL verification (DEVELOPMENT ONLY)
NODE_TLS_REJECT_UNAUTHORIZED=0

# ============================================================================
# Integration Endpoints
# ============================================================================

# Database configuration
DATABASE_URL=postgresql://user:password@localhost:5432/ipoready

# Other service endpoints
SERVICE_URL=http://localhost:3000
API_URL=http://localhost:3000/api

# ============================================================================
# Notes
# ============================================================================
#
# 1. SEDAR 2 Sandbox Registration:
#    - Visit: https://www.sedarplus.ca/
#    - Register for sandbox account
#    - Get API credentials from dashboard
#
# 2. SEC EDGAR Sandbox Registration:
#    - Visit: https://www.sec.gov/cgi-bin/browse-edgar
#    - Register for developer account
#    - Get CIK and API credentials
#
# 3. Webhook Testing with ngrok:
#    - Install: brew install ngrok
#    - Run: ngrok http 3000
#    - Set WEBHOOK_URL to your ngrok URL
#
# 4. Local Testing:
#    - Run: npm run dev
#    - Test endpoints: ./scripts/test-filing-endpoints.sh
#    - Run tests: npm run test:filing
#
# ============================================================================
