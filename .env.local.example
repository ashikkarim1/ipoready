# ─── CRITICAL: NEVER COMMIT .env.local ───────────────────────────────────
# This file is a template. Copy to .env.local and fill with REAL credentials.
# NEVER commit .env.local to git. It contains secrets.
# Generate new secrets for each environment (dev, staging, production).

# ─── NextAuth Configuration ──────────────────────────────────────────────────
# NEXTAUTH_SECRET: Generate with: openssl rand -hex 32
# NEXTAUTH_URL: Your app URL (http://localhost:3000 for dev, https://yourdomain.com for prod)
NEXTAUTH_URL=http://localhost:3800
NEXTAUTH_SECRET=generate-with-openssl-rand-hex-32-for-production

# ─── Database ────────────────────────────────────────────────────────────────
# DATABASE_URL: Neon PostgreSQL connection string
# Format: postgresql://user:password@host/database?sslmode=require&channel_binding=require
# For Canadian data residency, use Montreal region: ep-...-c-..-.ca-central-1.aws.neon.tech
DATABASE_URL=postgresql://user:password@host/database?sslmode=require&channel_binding=require

# ─── Application URLs ────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3800
NEXT_PUBLIC_APP_NAME=IPOReady.AI

# ─── Email (Resend) ──────────────────────────────────────────────────────────
# RESEND_API_KEY: Get from https://resend.com/api-keys
# Used for: welcome emails, password reset, billing notifications, trial reminders
RESEND_API_KEY=re_your_key_here

# ─── Web Push (VAPID) ────────────────────────────────────────────────────────
# Generate production keys with: npx web-push generate-vapid-keys
# NEXT_PUBLIC_VAPID_PUBLIC_KEY: Shared with clients (public, safe to expose)
# VAPID_PRIVATE_KEY: Keep secret (server-only)
# VAPID_SUBJECT: Your email address (for push service notifications)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_public_key_here
VAPID_PRIVATE_KEY=your_private_key_here
VAPID_SUBJECT=mailto:hello@ipoready.com

# ─── WhatsApp AI Companion (Twilio) ──────────────────────────────────────────
# Get from https://console.twilio.com
# TWILIO_WHATSAPP_FROM: WhatsApp-enabled Twilio number (format: whatsapp:+1XXXXXXXXXX)
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+1XXXXXXXXXX

# ─── AI Models ───────────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY: Get from https://console.anthropic.com/settings/api-keys
# Used for: smart document drafting, gap analysis, advisor insights
ANTHROPIC_API_KEY=sk-ant-your_key_here

# OPENAI_API_KEY: Get from https://platform.openai.com/api-keys
# Used for: Whisper audio transcription (WhatsApp voice messages)
OPENAI_API_KEY=sk-your_openai_key_here

# ─── Scheduled Jobs / Cron ───────────────────────────────────────────────────
# CRON_SECRET: Random string, sent as "Authorization: Bearer <secret>"
# Used by: trial expiry checks, payment retry, weekly digests
# Generate with: openssl rand -hex 32
CRON_SECRET=generate-with-openssl-rand-hex-32

# ─── Stripe (Payment Processing) ─────────────────────────────────────────────
# Get keys from https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY: Keep secret (server-only, never share)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY: Public key (safe to expose to client)
# STRIPE_WEBHOOK_SECRET: Get from https://dashboard.stripe.com/webhooks after creating endpoint
#   Endpoint URL: https://yourdomain.com/api/webhooks/stripe
#   Events: checkout.session.completed, customer.subscription.created, customer.subscription.updated,
#           customer.subscription.deleted, invoice.payment_failed, invoice.payment_succeeded
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ─── Stripe Price IDs (By Plan & Interval) ──────────────────────────────────
# Create in Stripe Dashboard → Products
# Each plan (Starter, Growth, Enterprise) needs 3 prices: monthly, 6-month, annual
# All prices should support multi-currency (USD primary, CAD secondary)
# Starter: $299/mo, $1,679/6mo (10% off), $2,989/year (17% off)
STRIPE_PRICE_STARTER_MONTHLY=price_starter_monthly_id_here
STRIPE_PRICE_STARTER_SIXMONTH=price_starter_sixmonth_id_here
STRIPE_PRICE_STARTER_ANNUAL=price_starter_annual_id_here

# Growth: $799/mo, $4,474/6mo (7% off), $7,990/year (17% off)
STRIPE_PRICE_GROWTH_MONTHLY=price_growth_monthly_id_here
STRIPE_PRICE_GROWTH_SIXMONTH=price_growth_sixmonth_id_here
STRIPE_PRICE_GROWTH_ANNUAL=price_growth_annual_id_here

# Enterprise: $1,999/mo, custom 6-month, $19,990/year (17% off)
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_enterprise_monthly_id_here
STRIPE_PRICE_ENTERPRISE_SIXMONTH=price_enterprise_sixmonth_id_here
STRIPE_PRICE_ENTERPRISE_ANNUAL=price_enterprise_annual_id_here

# ─── Storage (Vercel Blob) ───────────────────────────────────────────────────
# BLOB_READ_WRITE_TOKEN: Get from Vercel dashboard → Storage → Blob → Tokens
# Used for: document uploads, PDF storage, audit logs backup
# Encryption enabled automatically (AES-256 at rest)
BLOB_READ_WRITE_TOKEN=your_blob_token_here

# ─── Analytics ───────────────────────────────────────────────────────────────
# NEXT_PUBLIC_ANALYTICS_ID: (Optional) Google Analytics or Vercel Analytics ID
# Used for: user behavior tracking, feature adoption, conversion funnels
NEXT_PUBLIC_ANALYTICS_ID=your_analytics_id_here

# ─── Feature Flags ───────────────────────────────────────────────────────────
# Set to "true" to enable experimental features
# ENABLE_VENDOR_MARKETPLACE=true
# ENABLE_CONTINUOUS_DISCLOSURE=true
# ENABLE_INSIDER_REPORTING=true
