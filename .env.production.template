# IPOReady Production Environment Configuration Template
# 
# SECURITY WARNING: This template contains placeholder values.
# DO NOT use these values in production. Replace with actual production values.
# 
# For security best practices:
# 1. Generate random secrets using: openssl rand -hex 32
# 2. Store all secrets in Vercel Secrets Manager or similar
# 3. Never commit actual .env.production file to version control
# 4. Restrict access to production environment variables
# 5. Rotate secrets regularly (quarterly minimum)
#
# Last Updated: June 1, 2026
# Applies To: Production Environment Only

# ============================================================================
# NEXTAUTH CONFIGURATION (CRITICAL - DO NOT USE DEVELOPMENT VALUES)
# ============================================================================

# NextAuth JWT secret - MUST be a random 32-byte hex string
# Generate with: openssl rand -hex 32
NEXTAUTH_SECRET=<GENERATE_RANDOM_HEX_32_BYTES>

# Production URL for NextAuth
NEXTAUTH_URL=https://app.ipoready.ai

# ============================================================================
# DATABASE CONFIGURATION (PostgreSQL via Neon)
# ============================================================================

# Neon PostgreSQL connection string
# Must include: sslmode=require&channel_binding=require for security
# Format: postgresql://username:password@host/database
DATABASE_URL=postgresql://user:password@host.neon.tech/ipoready?sslmode=require&channel_binding=require

# ============================================================================
# STRIPE PAYMENT INTEGRATION
# ============================================================================

# Stripe publishable key (can be public, but typically kept in env)
STRIPE_PUBLISHABLE_KEY=pk_live_<YOUR_LIVE_PUBLISHABLE_KEY>

# Stripe secret key (MUST be kept confidential)
STRIPE_SECRET_KEY=sk_live_<YOUR_LIVE_SECRET_KEY>

# Stripe webhook secret (for webhook signature verification)
STRIPE_WEBHOOK_SECRET=whsec_<YOUR_LIVE_WEBHOOK_SECRET>

# ============================================================================
# OAUTH PROVIDER CREDENTIALS
# ============================================================================

# Google OAuth (optional)
# Leave blank if not using Google authentication
GOOGLE_CLIENT_ID=<YOUR_GOOGLE_CLIENT_ID>
GOOGLE_CLIENT_SECRET=<YOUR_GOOGLE_CLIENT_SECRET>

# LinkedIn OAuth (optional)
# Leave blank if not using LinkedIn authentication
LINKEDIN_CLIENT_ID=<YOUR_LINKEDIN_CLIENT_ID>
LINKEDIN_CLIENT_SECRET=<YOUR_LINKEDIN_CLIENT_SECRET>

# ============================================================================
# FILE STORAGE (Vercel Blob)
# ============================================================================

# Vercel Blob token for storing documents and uploaded files
# Generate in Vercel dashboard: Settings > Storage > Blob
BLOB_READ_WRITE_TOKEN=<YOUR_VERCEL_BLOB_TOKEN>

# ============================================================================
# EMAIL SERVICE (Resend)
# ============================================================================

# Resend API key for sending emails
# Get from: https://resend.com/api-keys
RESEND_API_KEY=<YOUR_RESEND_API_KEY>

# ============================================================================
# SMS SERVICE (Twilio)
# ============================================================================

# Twilio Account SID
TWILIO_ACCOUNT_SID=<YOUR_TWILIO_ACCOUNT_SID>

# Twilio Auth Token
TWILIO_AUTH_TOKEN=<YOUR_TWILIO_AUTH_TOKEN>

# Twilio phone number for sending SMS
TWILIO_PHONE_NUMBER=<YOUR_TWILIO_PHONE_NUMBER>

# ============================================================================
# SCHEDULED JOBS & CRON SECURITY
# ============================================================================

# Secret for authenticating scheduled job requests
# Generate with: openssl rand -hex 32
# Used to prevent unauthorized access to cron endpoints
CRON_SECRET=<GENERATE_RANDOM_HEX_32_BYTES>

# ============================================================================
# ENVIRONMENT INDICATOR
# ============================================================================

# Must be set to 'production' to enable production security settings
NODE_ENV=production

# ============================================================================
# MONITORING, ANALYTICS & TRACKING (GDPR/CCPA Compliant)
# ============================================================================

# Google Analytics 4 Measurement ID
# Format: G-XXXXXXXXXX (10+ characters starting with G-)
# Setup: https://support.google.com/analytics/answer/9539556
# Note: Analytics only loads when users consent via cookie banner
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Application metrics monitoring provider (optional)
# Options: datadog, newrelic, otel, none (default: none)
# Metrics are collected server-side and are NOT affected by cookie consent
MONITORING_PROVIDER=

# DataDog API Key (only required if MONITORING_PROVIDER=datadog)
# Get from: https://app.datadoghq.com/account/settings/agent/latest
# Scope required: Metrics Write
DATADOG_API_KEY=

# New Relic License Key (only required if MONITORING_PROVIDER=newrelic)
# Get from: https://one.newrelic.com/launcher/nr1-core.home
# Account admin access required
NEW_RELIC_LICENSE_KEY=

# OpenTelemetry Exporter Endpoint (only required if MONITORING_PROVIDER=otel)
# Example: http://localhost:4317 or https://otel.example.com
# Supports gRPC and HTTP/protobuf endpoints
OTEL_EXPORTER_OTLP_ENDPOINT=

# Sentry error tracking (optional but recommended)
# Get from: https://sentry.io/account/settings/auth-tokens/
# Scope required: project:write event:write
SENTRY_DSN=https://your-sentry-key@sentry.io/your-project-id

# ============================================================================
# FEATURE FLAGS & CONFIGURATION
# ============================================================================

# Enable/disable features per environment
FEATURE_PROSPECTUS_BUILDER=true
FEATURE_CAP_TABLE_IMPORT=true
FEATURE_REAL_TIME_COLLABORATION=true

# Log level for server-side logging
LOG_LEVEL=info

# ============================================================================
# SECURITY NOTES
# ============================================================================
# 
# 1. NEXTAUTH_SECRET & CRON_SECRET:
#    - Must be cryptographically random 32-byte hex strings
#    - Generate: openssl rand -hex 32
#    - Rotate quarterly
#    - Never expose in logs or error messages
#
# 2. API Keys & Secrets:
#    - Store in Vercel Secrets Manager (preferred)
#    - Or use environment variable management service
#    - Restrict access to minimum necessary personnel
#    - Audit access logs regularly
#
# 3. Database Connection:
#    - sslmode=require: Enforces SSL/TLS encryption
#    - channel_binding=require: Protects against MITM attacks
#    - Do not use sslmode=disable in production
#
# 4. OAuth Credentials:
#    - Use separate app registrations for prod vs. staging
#    - Restrict OAuth redirect URIs to https://app.ipoready.ai
#    - Enable additional security features (PKCE, etc.)
#
# 5. Payment Processing:
#    - Use Stripe Live keys for production
#    - Verify webhook signature verification is enabled
#    - Monitor for unusual transaction patterns
#
# 6. File Storage:
#    - Use production Blob token only
#    - Enable access logging for compliance
#    - Implement automated cleanup of temporary files
#
# ============================================================================
# DEPLOYMENT CHECKLIST
# ============================================================================
# Before deploying to production:
#
# [ ] All secrets replaced with actual production values
# [ ] Database connection tested successfully
# [ ] All third-party credentials verified (Stripe, OAuth, etc.)
# [ ] NEXTAUTH_SECRET and CRON_SECRET are unique and random
# [ ] Secrets NOT committed to git or version control
# [ ] Access logs configured for audit trail
# [ ] Monitoring and alerting configured
# [ ] Backup procedures tested and documented
# [ ] Incident response plan reviewed and approved
# [ ] Team trained on security procedures
#
# ============================================================================
