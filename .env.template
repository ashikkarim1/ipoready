# ────────────────────────────────────────────────────────────────────────────
# PHASE 2: REGULATORY FILING INTEGRATIONS
# ────────────────────────────────────────────────────────────────────────────
# These integrations enable real-time filing status checking, document
# retrieval, and insider reporting monitoring. All are read-only connections.
# ────────────────────────────────────────────────────────────────────────────

# ─── SEDAR 2 (System for Electronic Document Analysis and Retrieval) ────────
# Canadian regulatory filing platform for TSXV, TSX, CSE, and other exchanges
# Primary use: prospectus status, annual reports, material change reports,
# insider ownership filings (insiders/reporting persons)

SEDAR2_API_KEY=your_sedar2_api_key_here
SEDAR2_API_SECRET=your_sedar2_api_secret_here
SEDAR2_BASE_URL=https://www.sedarplus.ca/api/v1
SEDAR2_ENVIRONMENT=production
# Sandbox available: https://www.sedarplus.ca/sandbox/api/v1 (requires separate sandbox credentials)
SEDAR2_SANDBOX_API_KEY=your_sedar2_sandbox_api_key_here
SEDAR2_SANDBOX_API_SECRET=your_sedar2_sandbox_api_secret_here

# SEDAR 2 Specific Configuration
# Request timeout (ms) - SEDAR+ API typical response: 2-5 seconds
SEDAR2_REQUEST_TIMEOUT=15000
# Cache filing status results for 1 hour (3600 seconds) to reduce API calls
SEDAR2_CACHE_TTL=3600
# Company search index type (for faster lookups)
SEDAR2_SEARCH_MODE=exact_match
# Enable automatic retry with exponential backoff on rate limiting
SEDAR2_AUTO_RETRY_ENABLED=true
SEDAR2_MAX_RETRIES=3

# ─── SEC EDGAR (Electronic Data Gathering, Online Retrieval) ────────────────
# US regulatory filing platform for NASDAQ, NYSE, OTC, and other US exchanges
# Primary use: prospectus status, 10-K/10-Q filings, Form 4 (insider trades),
# Schedule 13D, and other US disclosure documents

EDGAR_API_BASE_URL=https://www.sec.gov/cgi-bin/browse-edgar
EDGAR_SUBMISSIONS_URL=https://www.sec.gov/cgi-bin/viewer
# No API key required - SEC EDGAR is open-access (REST)
# However, you must include a User-Agent header identifying your application
EDGAR_USER_AGENT=IPOReady/1.0 (information request; +https://www.ipoready.ai)
# CIK (Central Index Key) lookup endpoint - cached for performance
EDGAR_CIK_LOOKUP_URL=https://www.sec.gov/files/company_tickers.json
# Edgar XBRL data for automated financial parsing
EDGAR_XBRL_BASE_URL=https://xbrl.sec.gov/cgi-bin/viewer
# Edgar filing status check interval (seconds) - how often to poll for new filings
EDGAR_CHECK_INTERVAL=86400
# Cache company CIK and filing data for 24 hours
EDGAR_CACHE_TTL=86400

# SEC EDGAR Specific Configuration
EDGAR_REQUEST_TIMEOUT=10000
# Rate limiting: SEC requests max 10 requests per second
EDGAR_RATE_LIMIT_PER_SECOND=5
# Retry failed requests (network errors only, not 404s)
EDGAR_AUTO_RETRY_ENABLED=true
EDGAR_MAX_RETRIES=2
# Form 4 (insider trading) notification threshold - days to look back
EDGAR_FORM4_LOOKBACK_DAYS=30

# ─── SEDI (System for Electronic Disclosure by Insiders) ──────────────────
# Canadian insider reporting database - read-only public access
# Primary use: check insider trading filings, blackout periods, director/officer transactions

SEDI_PUBLIC_PORTAL_URL=https://www.sedi.ca
# SEDI is a public portal - no API key required
# All lookups are via web scraping or CSV download from public search
SEDI_SEARCH_EXPORT_URL=https://www.sedi.ca/sedi/SVTSearch.do
SEDI_REPORT_DOWNLOAD_URL=https://www.sedi.ca/sedi/SVTExport.do
SEDI_CACHE_TTL=604800
# SEDI lookback window (days) for insider transaction alerts
SEDI_LOOKBACK_DAYS=90

# ─── TSX/TSXV COMPANY LISTING STATUS ───────────────────────────────────────
# Exchange listing application status and company information
# No formal API - status checks via web portal lookup

TSX_LISTING_PORTAL_URL=https://www.tmx.com/en/listings
TSXV_LISTING_PORTAL_URL=https://www.tsxventure.com/listings
# Application status lookup (manual or via exchange customer portal)
TSX_COMPANY_SEARCH_URL=https://www.tmx.com/en/tools/company-search
TSXV_COMPANY_SEARCH_URL=https://www.tsxventure.com/tools/company-search

# ─── CSE (Canadian Securities Exchange) LISTING STATUS ──────────────────────

CSE_LISTING_PORTAL_URL=https://www.cse.ca
CSE_COMPANY_SEARCH_URL=https://www.cse.ca/listings

