# ========================================================================
# SEDAR 2 Configuration (Canada)
# ========================================================================
# Required: Get credentials from https://www.sedar.com/developers
# Sandbox: Use https://sandbox-api.sedar.ca for testing
# Production: Use https://api.sedar.ca for live filings

# SEDAR 2 OAuth2 Client Credentials
SEDAR2_CLIENT_ID=your_client_id_here
SEDAR2_CLIENT_SECRET=your_client_secret_here

# SEDAR 2 API Configuration
SEDAR2_API_BASE_URL=https://sandbox-api.sedar.ca
# Production: https://api.sedar.ca

# SEDAR 2 Company Registration (required for test account setup)
SEDAR2_TEST_COMPANY_CIK=0000000000  # Your test CIK number from SEDAR

# ========================================================================
# SEC EDGAR Configuration (United States)
# ========================================================================
# Public API - No credentials required
# Sandbox: https://www.sec.gov/cgi-bin (test environment)
# Production: Same endpoint (SEC EDGAR is public)

# SEC EDGAR Configuration
SEC_EDGAR_API_BASE_URL=https://www.sec.gov/cgi-bin
SEC_EDGAR_TEST_CIK=0000000000  # Your test CIK number
SEC_EDGAR_USER_AGENT=IPOReady (contact@ipoready.com)  # Required by SEC

# Rate limiting (SEC allows ~10 requests per second)
SEC_EDGAR_RATE_LIMIT_RPS=8

# ========================================================================
# Filing System Configuration
# ========================================================================

# Enable/Disable filing systems in production
FILING_SYSTEM_SEDAR2_ENABLED=true
FILING_SYSTEM_SEC_EDGAR_ENABLED=true

# Webhook signature verification (required for production)
FILING_WEBHOOK_SECRET_SEDAR2=your_webhook_secret_here
FILING_WEBHOOK_SECRET_SEC_EDGAR=your_webhook_secret_here

# Logging
FILING_LOG_LEVEL=info  # debug, info, warn, error
FILING_LOG_API_CALLS=true  # Log all API calls (disable in production if verbose)

# ========================================================================
# Sandbox vs Production
# ========================================================================
# When testing:
# - Use sandbox credentials and sandbox API endpoints
# - Test with sample companies before going live
# - Verify webhook endpoints are reachable

# When going to production:
# - Switch to production credentials
# - Update API endpoints to production URLs
# - Test with real (but non-IPO) company data first
