# E2E Testing Environment Variables
# Copy this file to .env.test and update with your test environment

# Application
BASE_URL=http://localhost:3000
NEXTAUTH_SECRET=test-secret-key-change-in-production-12345678

# Database (PostgreSQL - Neon or local)
DATABASE_URL=postgresql://user:password@localhost:5432/ipoready_test

# Email Service (for verification emails in tests)
RESEND_API_KEY=test_key_e2e_testing

# OAuth Providers (Optional - for OAuth flow testing)
# Note: These should be test/sandbox credentials only
GOOGLE_CLIENT_ID=test-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=test-client-secret

LINKEDIN_CLIENT_ID=test-linkedin-client-id
LINKEDIN_CLIENT_SECRET=test-linkedin-client-secret

# AWS S3 (for document storage testing)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test-access-key
AWS_SECRET_ACCESS_KEY=test-secret-key
AWS_S3_BUCKET=ipoready-test

# OpenAI (for AI-powered features testing)
OPENAI_API_KEY=sk-test-key-for-e2e-testing

# Stripe (for payment flow testing - use test keys)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_test_key
STRIPE_SECRET_KEY=sk_test_your_test_secret

# Twilio (for SMS notifications testing)
TWILIO_ACCOUNT_SID=test_account_sid
TWILIO_AUTH_TOKEN=test_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Slack (for Slack integration testing)
SLACK_CLIENT_ID=test-slack-client-id
SLACK_CLIENT_SECRET=test-slack-client-secret

# Google Drive (for document integration testing)
GOOGLE_DRIVE_CLIENT_ID=test-drive-client-id
GOOGLE_DRIVE_CLIENT_SECRET=test-drive-client-secret

# Feature Flags
ENABLE_OAUTH_TESTING=true
ENABLE_DOCUMENT_UPLOAD_TESTING=true
ENABLE_EMAIL_TESTING=false

# Playwright Configuration
PLAYWRIGHT_TIMEOUT=30000
PLAYWRIGHT_WORKERS=4
PLAYWRIGHT_RETRIES=2

# Logging
LOG_LEVEL=debug
DEBUG=ipoready:*

# Test Database
TEST_DB_RESET_BEFORE_SUITE=true
TEST_DB_RESET_AFTER_SUITE=true
