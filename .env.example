# ─── CRITICAL: NEVER COMMIT .env.local ───────────────────────────────────
# This file is a template. Copy to .env.local and fill with REAL credentials.
# NEVER commit .env.local to git. It contains secrets.
# Generate new secrets for each environment (dev, staging, production).

NEXTAUTH_URL=http://localhost:3800
NEXTAUTH_SECRET=generate-with-openssl-rand-hex-32-for-production
DATABASE_URL=postgresql://user:password@host/database?sslmode=require&channel_binding=require
NEXT_PUBLIC_APP_URL=http://localhost:3800
NEXT_PUBLIC_APP_NAME=IPOReady.AI
RESEND_API_KEY=re_your_key_here
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_public_key_here
VAPID_PRIVATE_KEY=your_private_key_here
VAPID_SUBJECT=mailto:hello@ipoready.com
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+1XXXXXXXXXX
ANTHROPIC_API_KEY=sk-ant-your_key_here
OPENAI_API_KEY=sk-your_openai_key_here
CRON_SECRET=generate-with-openssl-rand-hex-32
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_PRICE_STARTER_MONTHLY=price_starter_monthly_id_here
STRIPE_PRICE_STARTER_SIXMONTH=price_starter_sixmonth_id_here
STRIPE_PRICE_STARTER_ANNUAL=price_starter_annual_id_here
STRIPE_PRICE_GROWTH_MONTHLY=price_growth_monthly_id_here
STRIPE_PRICE_GROWTH_SIXMONTH=price_growth_sixmonth_id_here
STRIPE_PRICE_GROWTH_ANNUAL=price_growth_annual_id_here
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_enterprise_monthly_id_here
STRIPE_PRICE_ENTERPRISE_SIXMONTH=price_enterprise_sixmonth_id_here
STRIPE_PRICE_ENTERPRISE_ANNUAL=price_enterprise_annual_id_here
BLOB_READ_WRITE_TOKEN=your_blob_token_here
NEXT_PUBLIC_ANALYTICS_ID=your_analytics_id_here
# ─── Rate Limiting ─────────────────────────────────────────────────────────
# Redis connection for distributed rate limiting (optional)
# If not configured, rate limiting uses in-memory store (single instance only)
# For production: use Redis (AWS ElastiCache, UpStash, or self-hosted)
# Format: redis://[:password]@host:port
REDIS_URL=redis://localhost:6379
